#!/usr/bin/env bash
set -euo pipefail

OUT_DIR="$HOME/Pictures/Screenshots"
mkdir -p "$OUT_DIR"

TS="$(date +%Y-%m-%d_%H-%M-%S)"
JPG="$OUT_DIR/screenshot_${TS}.jpg"

# Temp file for PNG (browsers need PNG in clipboard)
TMP_PNG=$(mktemp --suffix=.png)
trap "rm -f $TMP_PNG" EXIT

GEOM="$(slurp)"

# Capture as PNG
grim -g "$GEOM" "$TMP_PNG"

# Save as JPG for storage (smaller files, no duplicates)
convert "$TMP_PNG" -quality 85 "$JPG"

# Copy PNG to clipboard (Firefox/Zen require image/png)
wl-copy -t image/png < "$TMP_PNG"

notify-send "📸 Screenshot saved to $JPG (clipboard)"

