#!/usr/bin/env bash
set -euo pipefail

OUT_DIR="$HOME/Pictures/Screenshots"
TS="$(date +%Y-%m-%d_%H-%M-%S)"
PNG="$OUT_DIR/satty-${TS}.png"
JPG="$OUT_DIR/screenshot_${TS}.jpg"

TMP_PNG=$(mktemp --suffix=.png)
trap "rm -f $TMP_PNG" EXIT

grim -g "$(slurp)" -t ppm - | satty --filename - --output-filename "$PNG"

# If user saved from satty, convert and copy
if [ -f "$PNG" ]; then
    convert "$PNG" -quality 85 "$JPG"
    rm "$PNG"
    wl-copy -t image/png < <(convert "$JPG" png:-)
    notify-send "📸 Screenshot saved to $JPG (clipboard)"
fi
